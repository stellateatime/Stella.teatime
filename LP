<script>
const FC = {
  steps: [
    {
      q: "今日はどんな気分ですか？",
      opts: [
        { label: "すっきりしたい", next: 1 },
        { label: "ほっとしたい", next: 2 },
        { label: "特別な気分", next: 3 },
        { label: "あたたかく包まれたい", next: 4 },
        { label: "やさしくほぐれたい", next: 5 }
      ]
    },
    // 1: すっきり
    {
      q: "どんなすっきりを？",
      opts: [
        { label: "爽やかで華やか", result: "ダージリン" },
        { label: "深くすっきり", result: "ウヴァ" }
      ]
    },
    // 2: ほっとしたい
    {
      q: "どんな香りが好きですか？",
      opts: [
        { label: "スモーキーで深い", result: "キームン" },
        { label: "やさしい和の香り", result: "光太夫和紅茶" }
      ]
    },
    // 3: 特別
    {
      q: "どんな特別さを感じたいですか？",
      opts: [
        { label: "この土地のストーリーを", result: "光太夫和紅茶" },
        { label: "Stellaの世界観を", result: "光太夫ブレンドティー" }
      ]
    },
    // 4: あたたかく包まれたい → ミルク系
    {
      q: "ミルクはどちらがお好みですか？",
      opts: [
        { label: "しっかりとしたコク", result: "ロイヤルミルクティー" },
        { label: "ふわっとやさしく", result: "ティーラテ" }
      ]
    },
    // 5: やさしくほぐれたい → ハーブ
    {
      q: "心と体、どちらをケアしたいですか？",
      opts: [
        { label: "心をやすめたい", result: "ハーブティー（カモミール）" },
        { label: "体をととのえたい", result: "ハーブティー（ローズヒップ）" },
        { label: "おまかせで", result: "ハーブティー（本日のブレンド）" }
      ]
    }
  ],
  teas: {
    "ダージリン": {
      desc: "マスカットのような華やかな香り。\n気持ちをリフレッシュさせてくれる、\n紅茶の女王と呼ばれる一杯。"
    },
    "ウヴァ": {
      desc: "清涼感のある深みが特徴。\nメントール様の香りとしっかりしたコクが\n気持ちをすっきり整えてくれます。"
    },
    "キームン": {
      desc: "中国・祁門産の深みある紅茶。\nスモーキーでフルーティーな香りが、\nゆっくりと心をほぐします。"
    },
    "光太夫和紅茶": {
      desc: "大黒屋光太夫の故郷・白子の精神を宿す\n国産の和紅茶。\nやさしく、奥深い一杯。"
    },
    "光太夫ブレンドティー": {
      desc: "Stella tea timeが生み出す\nオリジナルブレンド。\n旅と物語を一杯に凝縮した、特別な紅茶。"
    },
    "ロイヤルミルクティー": {
      desc: "茶葉をミルクで丁寧に煮出した、\nコクと甘みが深く溶け合う一杯。\nそっと包み込まれるような温かさ。"
    },
    "ティーラテ": {
      desc: "スチームミルクのやわらかさと\n紅茶の香りが溶け合う、\nふわっとやさしいカフェスタイルの一杯。"
    },
    "ハーブティー（カモミール）": {
      desc: "リンゴのような甘い香りのカモミール。\n心をそっとほぐし、\nゆっくりとした時間へ誘います。"
    },
    "ハーブティー（ローズヒップ）": {
      desc: "ビタミン豊富なローズヒップ。\n鮮やかなルビー色と\n爽やかな酸味で体の内側から整えます。"
    },
    "ハーブティー（本日のブレンド）": {
      desc: "季節と気分に合わせた、\nその日だけのハーブブレンド。\nStellaにおまかせの、一期一会の一杯。"
    }
  },
  current: 0,
  history: []
};

function fcRender() {
  const step = FC.steps[FC.current];
  const qEl = document.getElementById('fc-question');
  const oEl = document.getElementById('fc-options');
  const rEl = document.getElementById('fc-result');
  const prog = document.getElementById('fc-progress');

  rEl.style.display = 'none';
  qEl.style.display = '';
  oEl.style.display = 'flex';

  qEl.textContent = step.q;
  oEl.innerHTML = '';

  step.opts.forEach(opt => {
    const btn = document.createElement('button');
    btn.textContent = opt.label;
    btn.style.cssText = `
      font-family:'Noto Serif JP','Hiragino Mincho ProN',serif;
      font-size:13px;
      font-weight:300;
      letter-spacing:0.08em;
      color:rgba(255,255,255,0.9);
      background:transparent;
      border:1px solid rgba(201,169,110,0.45);
      padding:12px 20px;
      cursor:pointer;
      transition:all 0.3s;
      line-height:1.4;
    `;
    btn.onmouseover = () => { btn.style.background='rgba(201,169,110,0.18)'; btn.style.borderColor='var(--gold)'; btn.style.color='#fff'; };
    btn.onmouseout  = () => { btn.style.background='transparent'; btn.style.borderColor='rgba(201,169,110,0.45)'; btn.style.color='rgba(255,255,255,0.9)'; };
    btn.onclick = () => {
      FC.history.push(FC.current);
      if (opt.result) {
        fcShowResult(opt.result);
      } else {
        FC.current = opt.next;
        fcRender();
      }
    };
    oEl.appendChild(btn);
  });

  prog.innerHTML = '';
  const total = 2;
  const done = FC.history.length;
  for (let i = 0; i < total; i++) {
    const dot = document.createElement('div');
    dot.style.cssText = `
      width:6px;height:6px;border-radius:50%;
      background:${i < done ? 'var(--gold)' : 'rgba(201,169,110,0.25)'};
      transition:background 0.4s;
    `;
    prog.appendChild(dot);
  }
}

function fcShowResult(teaName) {
  const tea = FC.teas[teaName];
  document.getElementById('fc-question').style.display = 'none';
  document.getElementById('fc-options').style.display = 'none';
  document.getElementById('fc-result').style.display = 'block';
  document.getElementById('fc-tea-name').textContent = teaName;
  document.getElementById('fc-tea-desc').textContent = tea.desc;
  const prog = document.getElementById('fc-progress');
  prog.querySelectorAll('div').forEach(d => d.style.background = 'var(--gold)');
}

function fcReset() {
  FC.current = 0;
  FC.history = [];
  fcRender();
}

fcRender();
</script>

