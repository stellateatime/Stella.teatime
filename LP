<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>STELLA tea time — 鈴鹿・白子の紅茶専門店</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Noto+Serif+JP:wght@200;300;400&family=EB+Garamond:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --rose: #C4887A;
    --rose-deep: #A66457;
    --rose-pale: #EDD8D2;
    --gold: #C9A96E;
    --gold-light: #E2C99A;
    --cream: #FAF6F1;
    --ivory: #F5EFE6;
    --charcoal: #2C2420;
    --warm-gray: #8A7C76;
    --text: #3A2E2A;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  /* iOSで明朝体を確実に適用 */
  :lang(ja), p, h1, h2, h3, h4, span, div, a, blockquote {
    -webkit-text-size-adjust: 100%;
  }

  .serif-ja {
    font-family: 'Noto Serif JP', 'Yu Mincho', 'YuMincho', 'Hiragino Mincho ProN', 'Hiragino Mincho Pro', serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Noto Serif JP', 'Yu Mincho', 'YuMincho', 'Hiragino Mincho ProN', 'Hiragino Mincho Pro', 'HGS明朝E', serif;
    background: var(--cream);
    color: var(--text);
    overflow-x: hidden;
  }

  /* ── NOISE TEXTURE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.5;
  }

  /* ── HERO ── */
  .hero {
    min-height: 100svh;
    display: grid;
    grid-template-rows: 1fr auto;
    background: var(--rose);
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 30% 60%, rgba(201,169,110,0.18) 0%, transparent 60%),
      radial-gradient(ellipse 50% 70% at 75% 30%, rgba(255,240,230,0.12) 0%, transparent 50%);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 24px 40px;
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .hero-eyebrow {
    font-family: 'EB Garamond', serif;
    font-size: 11px;
    letter-spacing: 0.35em;
    color: var(--gold-light);
    text-transform: uppercase;
    opacity: 0;
    animation: fadeUp 1s ease 0.3s forwards;
  }

  .hero-logo {
    margin-top: 28px;
    opacity: 0;
    animation: fadeUp 1.2s ease 0.5s forwards;
  }

  .hero-logo .stella {
    font-family: 'Cormorant Garamond', 'EB Garamond', 'Times New Roman', Georgia, serif;
    font-size: clamp(52px, 12vw, 96px);
    font-weight: 300;
    letter-spacing: 0.28em;
    color: var(--gold);
    line-height: 1;
    display: block;
  }

  .hero-logo .divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 12px 0;
    justify-content: center;
  }

  .hero-logo .divider-line {
    height: 1px;
    width: 60px;
    background: var(--gold);
    opacity: 0.6;
  }

  .hero-logo .divider-star {
    color: var(--gold);
    font-size: 8px;
    opacity: 0.8;
  }

  .hero-logo .teatime {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(22px, 5vw, 38px);
    font-weight: 300;
    letter-spacing: 0.5em;
    color: var(--gold-light);
    display: block;
  }

  .hero-tagline {
    margin-top: 40px;
    font-size: clamp(13px, 2.5vw, 16px);
    font-weight: 200;
    color: rgba(255,255,255,0.75);
    letter-spacing: 0.15em;
    line-height: 2.2;
    opacity: 0;
    animation: fadeUp 1.2s ease 0.8s forwards;
  }

  .hero-ig {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 32px;
    font-family: 'EB Garamond', serif;
    font-size: 11px;
    letter-spacing: 0.3em;
    color: var(--gold-light);
    text-decoration: none;
    border: 1px solid rgba(201,169,110,0.35);
    padding: 10px 24px;
    opacity: 0;
    animation: fadeUp 1s ease 1.1s forwards;
    transition: border-color 0.3s, color 0.3s;
  }

  .hero-ig:hover {
    border-color: var(--gold);
    color: var(--gold);
  }

  .hero-scroll {
    padding: 40px 0 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    position: relative;
    z-index: 2;
    opacity: 0;
    animation: fadeIn 1s ease 1.5s forwards;
  }

  .hero-scroll span {
    font-family: 'EB Garamond', serif;
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--gold-light);
    opacity: 0.7;
    text-transform: uppercase;
  }

  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--gold-light), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 0.9; transform: scaleY(1.1); }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 500;
    padding: 20px 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: linear-gradient(to bottom, rgba(196,136,122,0.3), transparent);
    backdrop-filter: blur(2px);
    mix-blend-mode: normal;
  }

  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    letter-spacing: 0.3em;
    color: var(--gold-light);
    text-decoration: none;
    font-weight: 300;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    font-family: 'EB Garamond', serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.3s;
  }

  .nav-links a:hover { color: var(--gold-light); }

  /* ── SECTION BASE ── */
  section {
    padding: clamp(48px, 7vw, 88px) clamp(24px, 6vw, 80px);
  }

  /* セクション切り替えの上品な区切りライン */
  section + section,
  section + div > .techcafe,
  div[style*="charcoal"] + section {
    border-top: 1px solid rgba(201, 169, 110, 0.14);
  }

  /* セクション divider */
  .section-divider {
    height: clamp(24px, 4vw, 48px);
    background: inherit;
  }

  .section-label {
    font-family: 'EB Garamond', serif;
    font-size: 10px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--gold);
    display: block;
    margin-bottom: 24px;
  }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(32px, 6vw, 56px);
    line-height: 1.3;
    letter-spacing: 0.08em;
  }

  /* ── CONCEPT ── */
  .concept {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 8vw, 100px);
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
  }

  .concept-visual { order: 1; }
  .concept-text   { order: 2; }

  @media (max-width: 768px) {
    .concept { grid-template-columns: 1fr; }
    .concept-visual { order: 1; }
    .concept-text   { order: 2; }
    .nav-links { display: none; }
  }

  .concept-visual {
    aspect-ratio: 4/3;
    background: var(--rose);
    position: relative;
    overflow: hidden;
  }

  .concept-visual::before {
    content: '';
    position: absolute;
    inset: 16px;
    border: 1px solid rgba(201,169,110,0.4);
    z-index: 2;
  }

  .concept-visual-inner {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 80% at 50% 40%, rgba(201,169,110,0.15) 0%, transparent 70%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .concept-visual-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 300;
    font-style: italic;
    color: rgba(230, 200, 155, 0.92);
    letter-spacing: 0.05em;
    line-height: 1.4;
    text-align: center;
    padding: 24px;
    z-index: 3;
    position: relative;
    word-break: keep-all;
  }

  .concept-text .section-title {
    margin-bottom: 32px;
    color: var(--rose-deep);
  }

  .concept-body {
    font-size: clamp(14px, 1.6vw, 16px);
    font-weight: 200;
    line-height: 2.4;
    color: var(--warm-gray);
    letter-spacing: 0.05em;
  }

  .concept-body p + p {
    margin-top: 20px;
  }

  .concept-quote {
    margin-top: 40px;
    padding-left: 20px;
    border-left: 2px solid var(--gold);
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 20px;
    font-weight: 300;
    color: var(--rose-deep);
    line-height: 1.8;
    letter-spacing: 0.06em;
  }

  /* ── HISTORY ── */
  .history {
    background: var(--rose);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .history::before {
    content: 'HISTORY';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(80px, 18vw, 180px);
    font-weight: 300;
    color: rgba(201,169,110,0.08);
    letter-spacing: 0.2em;
    pointer-events: none;
    white-space: nowrap;
  }

  .history-inner {
    max-width: 680px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .history .section-label { color: var(--gold-light); }
  .history .section-title { color: var(--gold); margin-bottom: 40px; }

  .history-body {
    font-size: clamp(14px, 1.6vw, 16px);
    font-weight: 300;
    line-height: 2.6;
    color: rgba(255,255,255,0.88);
    letter-spacing: 0.06em;
  }

  .history-name {
    margin-top: 48px;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(18px, 3vw, 24px);
    font-style: italic;
    color: var(--gold-light);
    letter-spacing: 0.15em;
  }

  /* ── TIMELINE ── */
  .timeline {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    max-width: 420px;
    margin-left: auto;
    margin-right: auto;
    text-align: left;
  }

  .tl-item {
    display: grid;
    grid-template-columns: 64px 24px 1fr;
    gap: 0 16px;
    align-items: start;
    width: 100%;
  }

  .tl-year {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 300;
    color: var(--gold);
    letter-spacing: 0.05em;
    line-height: 1;
    padding-top: 2px;
    text-align: right;
  }

  .tl-dot {
    width: 10px;
    height: 10px;
    border: 2px solid var(--gold);
    border-radius: 50%;
    margin: 4px auto 0;
    background: transparent;
    flex-shrink: 0;
  }

  .tl-dot--now {
    background: var(--gold);
    box-shadow: 0 0 0 4px rgba(201,169,110,0.2);
  }

  .tl-text {
    padding-bottom: 32px;
  }

  .tl-place {
    font-family: 'Cormorant Garamond', serif;
    font-size: 19px;
    font-weight: 400;
    color: #fff;
    letter-spacing: 0.12em;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .tl-badge {
    font-family: 'EB Garamond', serif;
    font-size: 9px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--charcoal);
    background: var(--gold);
    padding: 3px 8px;
    vertical-align: middle;
  }

  .tl-desc {
    font-size: 13px;
    font-weight: 300;
    color: rgba(255,255,255,0.72);
    line-height: 2;
    letter-spacing: 0.06em;
  }

  .tl-line {
    width: 1px;
    height: 32px;
    background: rgba(201,169,110,0.3);
    margin: 0 0 0 calc(64px + 16px + 11px);
  }

  /* ── TECHCAFE ── */
  .techcafe {
    background: var(--charcoal);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px,8vw,100px);
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(48px,7vw,88px) clamp(24px,6vw,80px);
  }

  @media (max-width: 768px) {
    .techcafe { grid-template-columns: 1fr; }
  }

  .techcafe-label { color: var(--gold); }

  .techcafe-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(32px, 6vw, 52px);
    letter-spacing: 0.08em;
    line-height: 1.3;
    color: var(--gold-light);
    margin-bottom: 28px;
  }

  .techcafe-body {
    font-size: clamp(13px, 1.5vw, 15px);
    font-weight: 300;
    line-height: 2.5;
    color: rgba(255,255,255,0.78);
    letter-spacing: 0.06em;
  }

  .techcafe-links {
    margin-top: 36px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .techcafe-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'EB Garamond', serif;
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.3s;
  }

  .techcafe-link--stella {
    color: var(--gold);
    border-bottom: 1px solid rgba(201,169,110,0.35);
    padding-bottom: 3px;
    width: fit-content;
  }

  .techcafe-link--tech {
    color: rgba(255,255,255,0.45);
    border-bottom: 1px solid rgba(255,255,255,0.15);
    padding-bottom: 3px;
    width: fit-content;
  }

  .techcafe-link:hover { color: var(--gold-light); border-color: var(--gold-light); }

  .techcafe-visual {
    aspect-ratio: 1/1;
    background: rgba(201,169,110,0.05);
    border: 1px solid rgba(201,169,110,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .techcafe-visual::before {
    content: '';
    position: absolute;
    inset: 14px;
    border: 1px solid rgba(201,169,110,0.1);
  }

  .techcafe-visual-inner {
    text-align: center;
    z-index: 2;
    position: relative;
  }

  .techcafe-visual-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(28px, 5vw, 44px);
    font-weight: 300;
    color: rgba(201,169,110,0.5);
    letter-spacing: 0.2em;
    line-height: 1.4;
  }

  .techcafe-visual-sub {
    font-family: 'EB Garamond', serif;
    font-size: 11px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: rgba(201,169,110,0.3);
    margin-top: 12px;
  }
  .experience {
    background: var(--cream);
    text-align: center;
  }

  .experience .section-title {
    margin: 0 auto 64px;
    max-width: 600px;
    color: var(--rose-deep);
  }

  .exp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .exp-card {
    background: var(--ivory);
    padding: 48px 32px;
    position: relative;
    overflow: hidden;
    transition: background 0.4s;
  }

  .exp-card:hover {
    background: var(--rose-pale);
  }

  .exp-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 50%;
    transform: translateX(-50%);
    width: 40px; height: 1px;
    background: var(--gold);
    opacity: 0.5;
    transition: width 0.4s;
  }

  .exp-card:hover::after { width: 80px; }

  .exp-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 48px;
    font-weight: 300;
    color: rgba(196,136,122,0.2);
    line-height: 1;
    margin-bottom: 16px;
    font-style: italic;
  }

  .exp-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 400;
    color: var(--rose-deep);
    letter-spacing: 0.12em;
    margin-bottom: 16px;
  }

  .exp-desc {
    font-size: 13px;
    font-weight: 200;
    color: var(--warm-gray);
    line-height: 2.2;
    letter-spacing: 0.05em;
  }

  /* ── HOURS ── */
  .hours {
    background: var(--charcoal);
    text-align: center;
  }

  .hours .section-label { color: var(--gold); }
  .hours .section-title { color: var(--gold-light); margin-bottom: 64px; }

  .hours-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    max-width: 640px;
    margin: 0 auto;
    align-items: start;
  }

  @media (max-width: 600px) {
    .hours-grid {
      grid-template-columns: 1fr;
    }
    .hours-divider { display: none; }
  }

  .hours-block {
    padding: 32px;
  }

  .hours-block-label {
    font-family: 'EB Garamond', serif;
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    display: block;
  }

  .hours-time {
    font-family: 'Cormorant Garamond', serif;
    font-size: 32px;
    font-weight: 300;
    color: #fff;
    letter-spacing: 0.1em;
    line-height: 1.2;
  }

  .hours-days {
    margin-top: 12px;
    font-size: 12px;
    font-weight: 300;
    color: rgba(255,255,255,0.65);
    letter-spacing: 0.1em;
    line-height: 2;
  }

  .hours-divider {
    width: 1px;
    background: rgba(201,169,110,0.25);
    align-self: stretch;
    margin: 24px 0;
  }

  .hours-closed {
    margin-top: 48px;
    font-size: 12px;
    font-weight: 300;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.2em;
  }

  /* ── LOCATION ── */
  .location {
    background: var(--ivory);
    text-align: center;
  }

  .location .section-title {
    color: var(--rose-deep);
    margin-bottom: 16px;
  }

  .location-sub {
    font-size: 14px;
    font-weight: 200;
    color: var(--warm-gray);
    letter-spacing: 0.12em;
    margin-bottom: 56px;
    line-height: 2;
  }

  .location-card {
    background: var(--cream);
    border: 1px solid rgba(196,136,122,0.2);
    max-width: 480px;
    margin: 0 auto;
    padding: 48px 40px;
    position: relative;
  }

  .location-card::before {
    content: '';
    position: absolute;
    top: 12px; left: 12px; right: 12px; bottom: 12px;
    border: 1px solid rgba(201,169,110,0.15);
    pointer-events: none;
  }

  .map-wrap {
    max-width: 680px;
    margin: 48px auto 0;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(196,136,122,0.2);
  }

  .map-wrap::before {
    content: '';
    position: absolute;
    inset: 10px;
    border: 1px solid rgba(201,169,110,0.2);
    pointer-events: none;
    z-index: 2;
  }

  .map-wrap iframe {
    display: block;
    width: 100%;
    height: 340px;
    filter: sepia(30%) saturate(80%) brightness(0.97);
  }

  .map-link {
    display: inline-block;
    margin-top: 20px;
    font-family: 'EB Garamond', serif;
    font-size: 11px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
    border-bottom: 1px solid rgba(201,169,110,0.4);
    padding-bottom: 3px;
    transition: color 0.3s, border-color 0.3s;
  }

  .map-link:hover {
    color: var(--rose-deep);
    border-color: var(--rose-deep);
  }

  .location-item {
    margin-bottom: 24px;
  }

  .location-item-label {
    font-family: 'EB Garamond', serif;
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    display: block;
